<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>Sayan Ghosh · ML/AI Product Leader</title>
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link href="https://fonts.googleapis.com/css2?family=Geist+Mono:wght@400;500&family=DM+Sans:ital,opsz,wght@0,9..40,300;0,9..40,400;0,9..40,500;1,9..40,300&family=Playfair+Display:wght@400;500&display=swap" rel="stylesheet" />
  <style>
    *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }

    :root {
      --bg: #0d1117;
      --bg-2: #161b22;
      --bg-3: #21262d;
      --border: #30363d;
      --border-2: #444c56;
      --text: #e6edf3;
      --text-2: #8b949e;
      --text-3: #6e7681;
      --accent: #2ea043;
      --accent-2: #238636;
      --blue: #58a6ff;
      --blue-bg: #0d2137;
      --green: #3fb950;
      --orange: #d29922;
      --red: #f85149;
      --purple: #bc8cff;
      --teal: #39c5cf;
      --font-mono: 'Geist Mono', monospace;
      --font-body: 'DM Sans', sans-serif;
      --font-display: 'Playfair Display', serif;
      --radius: 6px;
      --radius-lg: 12px;
    }

    html { scroll-behavior: smooth; }

    body {
      background: var(--bg);
      color: var(--text);
      font-family: var(--font-body);
      font-size: 14px;
      line-height: 1.6;
      min-height: 100vh;
    }

    /* ─── TOP NAV ─── */
    nav {
      background: #010409;
      border-bottom: 1px solid var(--border);
      padding: 0 24px;
      height: 62px;
      display: flex;
      align-items: center;
      gap: 16px;
      position: sticky;
      top: 0;
      z-index: 100;
    }
    .nav-logo svg { fill: var(--text); width: 32px; height: 32px; }
    .nav-search {
      background: var(--bg-2);
      border: 1px solid var(--border);
      border-radius: var(--radius);
      padding: 5px 12px;
      color: var(--text-2);
      font-family: var(--font-body);
      font-size: 13px;
      width: 272px;
      outline: none;
    }
    .nav-search:focus { border-color: var(--blue); box-shadow: 0 0 0 3px rgba(88,166,255,.1); }
    .nav-links { display: flex; gap: 4px; margin-left: 8px; }
    .nav-link {
      color: var(--text);
      font-size: 14px;
      font-weight: 500;
      padding: 6px 10px;
      border-radius: var(--radius);
      text-decoration: none;
      transition: background .15s;
    }
    .nav-link:hover { background: var(--bg-3); }
    .nav-right { margin-left: auto; display: flex; align-items: center; gap: 12px; }
    .nav-btn {
      background: var(--accent-2);
      color: #fff;
      border: 1px solid rgba(240,246,252,.1);
      border-radius: var(--radius);
      padding: 5px 16px;
      font-size: 13px;
      font-weight: 500;
      cursor: pointer;
      font-family: var(--font-body);
      transition: background .15s;
    }
    .nav-btn:hover { background: #2ea043; }
    .avatar-sm {
      width: 32px; height: 32px;
      border-radius: 50%;
      background: linear-gradient(135deg, #0d419d, #1a7f64);
      display: flex; align-items: center; justify-content: center;
      font-size: 12px; font-weight: 500; color: #fff;
      cursor: pointer;
    }

    /* ─── LAYOUT ─── */
    .container { max-width: 1280px; margin: 0 auto; padding: 0 24px; }
    .layout {
      display: grid;
      grid-template-columns: 296px 1fr;
      gap: 24px;
      padding: 24px 0 48px;
      align-items: start;
    }

    /* ─── SIDEBAR ─── */
    .sidebar { position: sticky; top: 86px; }
    .avatar-lg {
      width: 296px; height: 296px;
      border-radius: 50%;
      background: linear-gradient(135deg, #0d419d 0%, #1a7f64 100%);
      display: flex; align-items: center; justify-content: center;
      font-family: var(--font-display);
      font-size: 96px;
      font-weight: 400;
      color: rgba(255,255,255,.9);
      border: 4px solid var(--bg);
      margin-bottom: 16px;
      box-shadow: 0 0 0 1px var(--border);
      letter-spacing: -2px;
    }
    .fullname {
      font-size: 24px;
      font-weight: 300;
      font-family: var(--font-display);
      color: var(--text);
      margin-bottom: 2px;
    }
    .username {
      font-size: 20px;
      font-weight: 300;
      color: var(--text-2);
      margin-bottom: 16px;
      font-family: var(--font-body);
    }
    .bio {
      font-size: 14px;
      color: var(--text);
      line-height: 1.6;
      margin-bottom: 16px;
    }
    .follow-btn {
      width: 100%;
      background: var(--bg-3);
      color: var(--text);
      border: 1px solid var(--border-2);
      border-radius: var(--radius);
      padding: 5px 16px;
      font-size: 14px;
      font-weight: 500;
      cursor: pointer;
      font-family: var(--font-body);
      margin-bottom: 16px;
      transition: background .15s, border-color .15s;
    }
    .follow-btn:hover { background: var(--bg-2); border-color: var(--blue); }
    .follow-stats {
      display: flex;
      gap: 8px;
      font-size: 14px;
      color: var(--text-2);
      margin-bottom: 16px;
      flex-wrap: wrap;
    }
    .follow-stats a { color: var(--text); font-weight: 500; text-decoration: none; }
    .follow-stats a:hover { color: var(--blue); }
    .meta-row {
      display: flex;
      align-items: center;
      gap: 8px;
      font-size: 14px;
      color: var(--text-2);
      margin-bottom: 8px;
    }
    .meta-row svg { width: 16px; height: 16px; fill: var(--text-3); flex-shrink: 0; }
    .meta-link { color: var(--blue); text-decoration: none; }
    .meta-link:hover { text-decoration: underline; }
    .sidebar-section { margin-top: 20px; }
    .sidebar-heading {
      font-size: 13px;
      font-weight: 500;
      color: var(--text);
      margin-bottom: 10px;
      border-bottom: 1px solid var(--border);
      padding-bottom: 8px;
      text-transform: uppercase;
      letter-spacing: .5px;
    }
    .pill {
      display: inline-block;
      background: var(--blue-bg);
      color: var(--blue);
      border: 1px solid rgba(88,166,255,.2);
      border-radius: 16px;
      padding: 2px 10px;
      font-size: 12px;
      font-family: var(--font-mono);
      margin: 2px 2px 2px 0;
    }
    .cert-row {
      display: flex; align-items: center; gap: 8px;
      font-size: 13px; color: var(--text-2);
      margin-bottom: 6px;
    }
    .cert-row::before {
      content: '';
      width: 6px; height: 6px;
      border-radius: 50%;
      background: var(--green);
      flex-shrink: 0;
    }
    .award-row {
      display: flex; align-items: flex-start; gap: 8px;
      font-size: 13px; color: var(--text-2);
      margin-bottom: 8px;
      line-height: 1.4;
    }
    .award-icon { font-size: 14px; flex-shrink: 0; }

    /* ─── MAIN ─── */
    .main { min-width: 0; }

    /* TABS */
    .tabs {
      display: flex;
      border-bottom: 1px solid var(--border);
      margin-bottom: 24px;
      overflow-x: auto;
    }
    .tab {
      padding: 8px 16px;
      font-size: 14px;
      color: var(--text-2);
      cursor: pointer;
      border-bottom: 2px solid transparent;
      margin-bottom: -1px;
      display: flex; align-items: center; gap: 6px;
      white-space: nowrap;
      transition: color .15s;
    }
    .tab:hover { color: var(--text); }
    .tab.active { color: var(--text); border-bottom-color: #fd8c73; font-weight: 500; }
    .tab-count {
      background: var(--bg-3);
      border: 1px solid var(--border);
      border-radius: 16px;
      padding: 1px 6px;
      font-size: 12px;
      color: var(--text-2);
    }

    /* PINNED */
    .section-label {
      font-size: 13px;
      font-weight: 500;
      color: var(--text-2);
      text-transform: uppercase;
      letter-spacing: .5px;
      margin-bottom: 12px;
    }
    .pinned-grid {
      display: grid;
      grid-template-columns: 1fr 1fr;
      gap: 12px;
      margin-bottom: 32px;
    }
    .pinned-card {
      background: var(--bg-2);
      border: 1px solid var(--border);
      border-radius: var(--radius);
      padding: 16px;
      transition: border-color .15s;
    }
    .pinned-card:hover { border-color: var(--border-2); }
    .pinned-title {
      display: flex; align-items: center; gap: 6px;
      font-size: 14px; font-weight: 500;
      color: var(--blue);
      margin-bottom: 6px;
      cursor: pointer;
      text-decoration: none;
    }
    .pinned-title:hover { text-decoration: underline; }
    .pinned-title svg { fill: var(--text-3); width: 14px; height: 14px; flex-shrink: 0; }
    .pinned-desc {
      font-size: 12px;
      color: var(--text-2);
      line-height: 1.5;
      margin-bottom: 12px;
    }
    .pinned-meta {
      display: flex; gap: 16px; align-items: center;
      font-size: 12px; color: var(--text-2);
    }
    .lang-dot {
      display: inline-block;
      width: 12px; height: 12px;
      border-radius: 50%;
      vertical-align: middle;
      margin-right: 4px;
    }

    /* CONTRIBUTION GRAPH */
    .contrib-card {
      background: var(--bg-2);
      border: 1px solid var(--border);
      border-radius: var(--radius-lg);
      padding: 16px;
      margin-bottom: 24px;
    }
    .contrib-header {
      display: flex; justify-content: space-between; align-items: center;
      margin-bottom: 16px;
    }
    .contrib-title { font-size: 14px; color: var(--text-2); }
    .contrib-title strong { color: var(--text); }
    .contrib-grid {
      display: flex; gap: 2px;
      overflow: hidden;
    }
    .contrib-week { display: flex; flex-direction: column; gap: 2px; }
    .contrib-day {
      width: 10px; height: 10px;
      border-radius: 2px;
    }
    .c0 { background: #161b22; }
    .c1 { background: #0e4429; }
    .c2 { background: #006d32; }
    .c3 { background: #26a641; }
    .c4 { background: #39d353; }
    .contrib-months {
      display: flex;
      justify-content: space-between;
      font-size: 11px;
      color: var(--text-3);
      font-family: var(--font-mono);
      margin-bottom: 4px;
    }

    /* EXPERIENCE */
    .exp-card {
      background: var(--bg-2);
      border: 1px solid var(--border);
      border-radius: var(--radius-lg);
      padding: 16px;
      margin-bottom: 16px;
    }
    .exp-entry {
      display: flex; align-items: flex-start; gap: 12px;
      padding: 12px 0;
      border-bottom: 1px solid var(--border);
    }
    .exp-entry:first-child { padding-top: 0; }
    .exp-entry:last-child { border-bottom: none; padding-bottom: 0; }
    .exp-icon {
      width: 36px; height: 36px;
      border-radius: var(--radius);
      display: flex; align-items: center; justify-content: center;
      font-size: 16px;
      flex-shrink: 0;
      margin-top: 2px;
    }
    .exp-body { flex: 1; min-width: 0; }
    .exp-company { font-size: 14px; font-weight: 500; color: var(--text); }
    .exp-role { font-size: 13px; color: var(--text-2); margin-bottom: 2px; }
    .exp-date { font-size: 12px; color: var(--text-3); font-family: var(--font-mono); }
    .exp-tags { display: flex; flex-wrap: wrap; gap: 4px; margin-top: 8px; }
    .exp-tag {
      background: var(--bg-3);
      border: 1px solid var(--border);
      border-radius: 4px;
      padding: 1px 7px;
      font-size: 11px;
      font-family: var(--font-mono);
      color: var(--text-3);
    }

    /* IMPACT METRICS */
    .metrics-grid {
      display: grid;
      grid-template-columns: repeat(3, 1fr);
      gap: 12px;
      margin-bottom: 24px;
    }
    .metric-card {
      background: var(--bg-2);
      border: 1px solid var(--border);
      border-radius: var(--radius-lg);
      padding: 16px;
      text-align: center;
      position: relative;
      overflow: hidden;
    }
    .metric-card::before {
      content: '';
      position: absolute;
      top: 0; left: 0; right: 0;
      height: 2px;
    }
    .metric-card.green::before { background: var(--green); }
    .metric-card.blue::before { background: var(--blue); }
    .metric-card.purple::before { background: var(--purple); }
    .metric-card.orange::before { background: var(--orange); }
    .metric-card.teal::before { background: var(--teal); }
    .metric-card.red::before { background: var(--red); }
    .metric-num {
      font-size: 28px;
      font-weight: 300;
      font-family: var(--font-display);
      color: var(--text);
      line-height: 1.1;
      margin-bottom: 4px;
    }
    .metric-label {
      font-size: 11px;
      color: var(--text-3);
      text-transform: uppercase;
      letter-spacing: .5px;
    }

    /* README section */
    .readme-card {
      background: var(--bg-2);
      border: 1px solid var(--border);
      border-radius: var(--radius-lg);
      overflow: hidden;
      margin-bottom: 24px;
    }
    .readme-header {
      display: flex; align-items: center; gap: 8px;
      padding: 10px 16px;
      background: var(--bg-3);
      border-bottom: 1px solid var(--border);
      font-size: 13px; color: var(--text-2);
      font-family: var(--font-mono);
    }
    .readme-header svg { width: 14px; height: 14px; fill: var(--text-3); }
    .readme-body { padding: 24px; }
    .readme-h1 {
      font-size: 28px;
      font-family: var(--font-display);
      font-weight: 400;
      color: var(--text);
      border-bottom: 1px solid var(--border);
      padding-bottom: 12px;
      margin-bottom: 16px;
    }
    .readme-h2 {
      font-size: 18px;
      font-weight: 500;
      color: var(--text);
      border-bottom: 1px solid var(--border);
      padding-bottom: 8px;
      margin: 24px 0 12px;
    }
    .readme-p { font-size: 14px; color: var(--text-2); line-height: 1.7; margin-bottom: 12px; }
    .readme-li {
      font-size: 14px; color: var(--text-2); line-height: 1.6;
      margin-bottom: 6px;
      padding-left: 20px;
      position: relative;
    }
    .readme-li::before {
      content: '▸';
      position: absolute; left: 0;
      color: var(--green);
    }
    .badge {
      display: inline-block;
      background: var(--bg-3);
      border: 1px solid var(--border);
      border-radius: 4px;
      padding: 3px 8px;
      font-size: 12px;
      font-family: var(--font-mono);
      color: var(--text-2);
      margin: 3px 2px;
    }
    .badge.green { background: rgba(63,185,80,.1); border-color: rgba(63,185,80,.3); color: var(--green); }
    .badge.blue { background: rgba(88,166,255,.1); border-color: rgba(88,166,255,.3); color: var(--blue); }
    .badge.purple { background: rgba(188,140,255,.1); border-color: rgba(188,140,255,.3); color: var(--purple); }
    .badge.orange { background: rgba(210,153,34,.1); border-color: rgba(210,153,34,.3); color: var(--orange); }
    code.inline {
      background: var(--bg-3);
      border: 1px solid var(--border);
      border-radius: 4px;
      padding: 1px 5px;
      font-family: var(--font-mono);
      font-size: 12px;
      color: var(--purple);
    }
    .highlight-box {
      background: rgba(88,166,255,.05);
      border: 1px solid rgba(88,166,255,.2);
      border-left: 3px solid var(--blue);
      border-radius: 0 var(--radius) var(--radius) 0;
      padding: 12px 16px;
      margin: 16px 0;
      font-size: 13px;
      color: var(--text-2);
      line-height: 1.6;
    }

    /* FOOTER */
    footer {
      border-top: 1px solid var(--border);
      padding: 24px;
      text-align: center;
      font-size: 12px;
      color: var(--text-3);
      font-family: var(--font-mono);
    }
    footer a { color: var(--text-3); text-decoration: none; }
    footer a:hover { color: var(--blue); }

    /* ANIMATIONS */
    @keyframes fadeUp {
      from { opacity: 0; transform: translateY(12px); }
      to   { opacity: 1; transform: translateY(0); }
    }
    .fade-up {
      animation: fadeUp .4s ease both;
    }
    .fade-up:nth-child(1) { animation-delay: .05s; }
    .fade-up:nth-child(2) { animation-delay: .1s; }
    .fade-up:nth-child(3) { animation-delay: .15s; }
    .fade-up:nth-child(4) { animation-delay: .2s; }

    /* RESPONSIVE */
    @media (max-width: 768px) {
      .layout { grid-template-columns: 1fr; }
      .sidebar { position: static; }
      .avatar-lg { width: 128px; height: 128px; font-size: 40px; }
      .pinned-grid { grid-template-columns: 1fr; }
      .metrics-grid { grid-template-columns: 1fr 1fr; }
      nav { padding: 0 12px; }
      .nav-search { width: 150px; }
      .nav-links { display: none; }
    }
    @media (max-width: 480px) {
      .metrics-grid { grid-template-columns: 1fr; }
    }
  </style>
</head>
<body>

<!-- NAV -->
<nav>
  <div class="nav-logo">
    <svg viewBox="0 0 16 16" xmlns="http://www.w3.org/2000/svg">
      <path d="M8 0C3.58 0 0 3.58 0 8c0 3.54 2.29 6.53 5.47 7.59.4.07.55-.17.55-.38 0-.19-.01-.82-.01-1.49-2.01.37-2.53-.49-2.69-.94-.09-.23-.48-.94-.82-1.13-.28-.15-.68-.52-.01-.53.63-.01 1.08.58 1.23.82.72 1.21 1.87.87 2.33.66.07-.52.28-.87.51-1.07-1.78-.2-3.64-.89-3.64-3.95 0-.87.31-1.59.82-2.15-.08-.2-.36-1.02.08-2.12 0 0 .67-.21 2.2.82.64-.18 1.32-.27 2-.27.68 0 1.36.09 2 .27 1.53-1.04 2.2-.82 2.2-.82.44 1.1.16 1.92.08 2.12.51.56.82 1.27.82 2.15 0 3.07-1.87 3.75-3.65 3.95.29.25.54.73.54 1.48 0 1.07-.01 1.93-.01 2.2 0 .21.15.46.55.38A8.013 8.013 0 0 0 16 8c0-4.42-3.58-8-8-8z"/>
    </svg>
  </div>
  <input class="nav-search" placeholder="Search or jump to…" />
  <nav class="nav-links">
    <a class="nav-link" href="#">Pull requests</a>
    <a class="nav-link" href="#">Issues</a>
    <a class="nav-link" href="#">Marketplace</a>
    <a class="nav-link" href="#">Explore</a>
  </nav>
  <div class="nav-right">
    <button class="nav-btn">+ New</button>
    <div class="avatar-sm">SG</div>
  </div>
</nav>

<!-- MAIN LAYOUT -->
<div class="container">
  <div class="layout">

    <!-- SIDEBAR -->
    <aside class="sidebar">
      <div class="avatar-lg">SG</div>
      <div class="fullname">Sayan Ghosh</div>
      <div class="username">sayans88</div>
      <p class="bio">ML/AI Product Leader &amp; Agile Delivery Lead. VP @ JP Morgan &amp; Chase. Building intelligent data platforms across fintech, energy &amp; manufacturing for 15+ years.</p>
      <button class="follow-btn">Follow</button>
      <div class="follow-stats">
        <a href="#">312 <span style="font-weight:300;color:var(--text-2)">followers</span></a>
        <span>·</span>
        <a href="#">148 <span style="font-weight:300;color:var(--text-2)">following</span></a>
      </div>

      <div class="meta-row">
        <svg viewBox="0 0 16 16"><path d="M1.75 2h12.5c.966 0 1.75.784 1.75 1.75v8.5A1.75 1.75 0 0 1 14.25 14H1.75A1.75 1.75 0 0 1 0 12.25v-8.5C0 2.784.784 2 1.75 2zm0 1.5a.25.25 0 0 0-.25.25v.4l6.5 4.334 6.5-4.335v-.4a.25.25 0 0 0-.25-.25H1.75zM14.5 7.23 8.5 11.08a.5.5 0 0 1-.5 0L2 7.23v5.02c0 .138.112.25.25.25h12.5a.25.25 0 0 0 .25-.25V7.23z"/></svg>
        <a class="meta-link" href="mailto:sayans88@gmail.com">sayans88@gmail.com</a>
      </div>
      <div class="meta-row">
        <svg viewBox="0 0 16 16"><path d="M8 0a8 8 0 1 1 0 16A8 8 0 0 1 8 0zM1.5 8a6.5 6.5 0 1 0 13 0 6.5 6.5 0 0 0-13 0zm2-1h1.25a.75.75 0 0 1 0 1.5H3.5v1.25a.75.75 0 0 1-1.5 0v-3.5a.75.75 0 0 1 .75-.75H4a.75.75 0 0 1 0 1.5H3.5V7z"/></svg>
        Atlanta, GA
      </div>
