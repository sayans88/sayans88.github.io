<script>
  // Contribution graph
  const grid = document.getElementById('contrib-grid');
  const levels = [0,0,1,0,1,2,1,0,2,3,2,1,0,1,2,3,4,3,2,1,2,3,3,4,4,3,2,1,2,3,2,1,0,1,2,3,2,3,4,3,2,1,0,1,2,3,2,1,0,1,2,3];
  for (let w = 0; w < 52; w++) {
    const week = document.createElement('div');
    week.className = 'contrib-week';
    const base = levels[w % levels.length];
    for (let d = 0; d < 7; d++) {
      const day = document.createElement('div');
      const v = Math.max(0, Math.min(4, base + (Math.random() > .65 ? 1 : 0) - (Math.random() > .65 ? 1 : 0)));
      day.className = 'contrib-day c' + Math.round(v);
      week.appendChild(day);
    }
    grid.appendChild(week);
  }

  // Month labels
  const months = document.getElementById('contrib-months');
  const labels = ['Apr','May','Jun','Jul','Aug','Sep','Oct','Nov','Dec','Jan','Feb','Mar'];
  labels.forEach(m => {
    const s = document.createElement('span');
    s.textContent = m;
    months.appendChild(s);
  });

  // Tab switching (visual only)
  document.querySelectorAll('.tab').forEach(tab => {
    tab.addEventListener('click', () => {
      document.querySelectorAll('.tab').forEach(t => t.classList.remove('active'));
      tab.classList.add('active');
    });
  });
</script>
